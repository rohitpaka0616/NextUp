# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# ── Auth.js / NextAuth v5 ───────────────────────────────
# Generate once: openssl rand -base64 32
AUTH_SECRET=

# Canonical site URL (no trailing slash).
# Local:        http://localhost:3000
# Vercel + domain: https://your-domain.com
AUTH_URL=http://localhost:3000

# Aliases (optional; same values as above):
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# ── App ─────────────────────────────────────────────────
# Email that receives admin API privileges (see ADMIN_EMAIL usage in API routes).
ADMIN_EMAIL=you@example.com

# ── AI Idea Generation (optional) ───────────────────────
# Use an OpenAI-compatible endpoint.
# Default base URL is OpenAI if OPENAI_BASE_URL is not set.
OPENAI_API_KEY=
# Optional: defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Optional: for other providers (OpenAI-compatible)
# OPENAI_BASE_URL=https://api.openai.com/v1
